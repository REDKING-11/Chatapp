<IfModule mod_headers.c>
    SetEnvIfNoCase Origin "^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$" CHATAPP_ALLOW_ORIGIN=$0
    Header always set Access-Control-Allow-Origin "%{CHATAPP_ALLOW_ORIGIN}e" env=CHATAPP_ALLOW_ORIGIN
    Header always set Vary "Origin"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Chatapp-Session-Name"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    Header always set Access-Control-Max-Age "86400"
</IfModule>

RewriteEngine On

RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
