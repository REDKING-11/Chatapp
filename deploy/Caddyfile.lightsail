# Public TLS edge for the Lightsail deployment.
#
# Public endpoints:
# - https://56.228.2.7/* -> chatapp-core on 127.0.0.1:8080
# - wss://56.228.2.7/ws/ -> chatapp-realtime on 127.0.0.1:3010
#
# Certificate paths assume Certbot-issued files have been copied into
# /etc/caddy/certs with group-readable permissions for the caddy service.

{
    # RFC 6066 forbids literal IPs in SNI, so clients often omit SNI when
    # connecting to https://56.228.2.7. This fallback lets Caddy choose the
    # loaded IP certificate anyway.
    default_sni 56.228.2.7
}

http://56.228.2.7 {
    redir https://56.228.2.7{uri} permanent
}

https://56.228.2.7 {
    tls /etc/caddy/certs/fullchain.pem /etc/caddy/certs/privkey.pem
    encode zstd gzip

    handle /ws* {
        reverse_proxy 127.0.0.1:3010
    }

    handle {
        reverse_proxy 127.0.0.1:8080
    }
}
